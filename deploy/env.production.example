# Production environment for the Symfony backend.
# In Forge: Site → "Environment" edits backend/.env.local. Paste these there and fill in
# the secrets. Generate strong random values for APP_SECRET and MERCURE_JWT_SECRET, e.g.:
#   php -r 'echo bin2hex(random_bytes(24)), PHP_EOL;'

APP_ENV=prod
APP_DEBUG=0
APP_SECRET=__CHANGE_ME_32+_hex__

# Forge created the MySQL DB/user when you provisioned the server.
DATABASE_URL="mysql://forge:__DB_PASSWORD__@127.0.0.1:3306/__DB_NAME__?serverVersion=8.0"

# Mercure: backend PUBLISHES to the local daemon; browsers SUBSCRIBE via the public URL
# (Nginx proxies /.well-known/mercure to 127.0.0.1:3000). Use the SAME secret in the
# Mercure daemon (see deploy/README.md).
MERCURE_URL=http://127.0.0.1:3000/.well-known/mercure
MERCURE_PUBLIC_URL=https://your-domain.com/.well-known/mercure
MERCURE_JWT_SECRET=__CHANGE_ME_long_random__

# Single-origin in prod => CORS is effectively unused, but keep it locked to your domain.
CORS_ALLOW_ORIGIN='^https?://your-domain\.com$'
